# Copy to .env and fill in. Everything here is OPTIONAL — the demo runs without it.

# --- Telegram push (leave blank to print alerts to the console) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- LINE Messaging API (optional) ---
LINE_CHANNEL_ACCESS_TOKEN=

# --- Polling cadence (seconds) ---
BASE_POLL_INTERVAL=30
HOT_POLL_INTERVAL=5

# --- Scalable mode (only needed with docker-compose) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://radar:radar@localhost:5432/radar
